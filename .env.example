# ── LLM backend ──
# NOTE: BYOK — each user supplies their OWN Groq key in-app (stored only in
# their browser, never here). You do NOT set a shared GROQ_API_KEY anymore.

# ── Web search grounding (server-side, shared) ──
# Brave Search API key — used for real company data. ONE shared key, paid by
# you (metered past the free $5/mo credit). Server-side only; never exposed to
# the browser. Get one at https://api-dashboard.search.brave.com/
# If left blank, the app still works but generates from model knowledge only.
BRAVE_API_KEY=

# ── Supabase auth + history (required for deployment with login) ──
# From your Supabase project → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Other LLM backends (optional, only if you switch AGENT_ENDPOINT) ──
ANTHROPIC_API_KEY=
